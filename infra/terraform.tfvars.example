aws_region   = "us-east-1"
aws_profile  = "records"
environment  = "dev"

db_name                  = "recordranch"
db_username              = "recordranch"
db_instance_class        = "db.t3.micro"
db_allocated_storage     = 20
db_max_allocated_storage = 100

# Set to true only during a planned major Postgres version upgrade apply.
# allow_major_version_upgrade = false

# SSM SecureString parameter name for the Discogs API token.
# Create the parameter out-of-band before running terraform apply:
#   aws ssm put-parameter --name "/records/prod/discogs-token" \
#     --value "<your_token>" --type SecureString --profile records
discogs_token_ssm_name = "/records/prod/discogs-token"
